@model CreateCategoryDto
@{
    Layout = null;
}

<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container">
    <br />
    <br />
    <form method="post">
        <label>Category</label>
        <input type="text" asp-for="CategoryName" class="form-control" />
        <br />
        <label>Category Icon</label>
        <input type="text" asp-for="IconUrl" class="form-control" />
        <br />
        <button class="btn btn-primary">Save the Category</button>
    </form>
</div>