			<div class="form-section">
				<div class="section-header">
					<div class="section-icon purple"><i class="bi bi-image"></i></div>
					<div>
						<div class="section-title">Tour Image</div>
						<div class="section-subtitle">Enter URL or upload a file</div>
					</div>
				</div>
				<div class="section-body">
					<div class="field-group">
						<label asp-for="ImageUrl" class="field-label">
							<i class="bi bi-link-45deg" style="color:#a0aec0;font-size:.85rem;"></i>
							Image URL
						</label>
						<div class="input-with-icon">
							<i class="bi bi-link-45deg input-icon"></i>
							<input asp-for="ImageUrl" type="url" class="form-control" placeholder="https://example.com/image.jpg" id="imageUrlInput" />

						</div>
						<div class="field-hint"><i class="bi bi-info-circle me-1"></i>Supports JPEG, PNG, WebP.</div>
						<img src="" alt="Image preview" class="url-preview-thumb" id="urlPreviewImg" />
						<span asp-validation-for="ImageUrl" class="text-danger-field"></span>
					</div>

					<div class="d-flex align-items-center gap-3 my-3">
						<div style="flex:1;height:1px;background:#e2e8f0;"></div>
						<span style="font-size:.73rem;color:#a0aec0;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">or</span>
						<div style="flex:1;height:1px;background:#e2e8f0;"></div>
