						<div class="upload-title">Drag and drop or click to select</div>
						<div class="upload-sub">PNG, JPG, WebP — Max. 5MB</div>
					</div>

					<div class="image-preview-box mt-3" id="previewBox">
						<img src="" alt="Uploaded image preview" id="previewImg" />
