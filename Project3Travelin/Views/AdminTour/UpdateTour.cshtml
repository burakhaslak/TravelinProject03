</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script>
		// ── CHAR COUNTERS ─────────────────────────────
		function initCounter(inputId, counterId, max) {
			const el = document.getElementById(inputId);
			const counter = document.getElementById(counterId);
			if (!el || !counter) return;
			function update() {
				const len = el.value.length;
				counter.textContent = len + ' / ' + max;
				counter.className = 'char-counter' + (len > max * .9 ? (len >= max ? ' danger' : ' warn') : '');
			}
			el.addEventListener('input', update);
			update();
		}

		initCounter('tourTitleInput', 'titleCounter', 120);
		initCounter('descInput', 'descCounter', 1000);
		initCounter('detailedDescInput', 'descCounter', 1000); // Eklediğin yeni alan için

		// ── STEPPER ────────────────────────────────────
		function stepperIncrement(inputId) {
			var input = document.getElementById(inputId);
			var max = parseInt(input.max) || 999999;
			if (parseInt(input.value) < max) {
				input.value = parseInt(input.value) + 1;
				updateSummary(); // Butona basınca özeti güncelle
			}
		}

		function stepperDecrement(inputId) {
			var input = document.getElementById(inputId);
			var min = parseInt(input.min) || 0;
			if (parseInt(input.value) > min) {
				input.value = parseInt(input.value) - 1;
				updateSummary(); // Butona basınca özeti güncelle
			}
		}

		// ── DURATION BUILDER ──────────────────────────
		function updateDuration() {
			const days   = parseInt(document.getElementById('dayCount').value)   || 0;
			const nights = parseInt(document.getElementById('nightCount').value) || 0;
			const text   = days + ' Days / ' + nights + ' Nights';

			const hiddenInput = document.getElementById('dayNightHidden');
			const durationPreview = document.getElementById('durationText');

			if(hiddenInput) hiddenInput.value = text;
			if(durationPreview) durationPreview.textContent = text;

			updateSummary();
		}

		document.getElementById('dayCount').addEventListener('input', updateDuration);
		document.getElementById('nightCount').addEventListener('input', updateDuration);

		// ── LIVE SUMMARY (ÖZET GÜNCELLEME) ──────────────────────────────
		function updateSummary() {
			// HTML'deki ID'lerle eşleşen değerleri alıyoruz
			const title    = document.getElementById('tourTitleInput').value.trim();
			const country  = document.querySelector('select[name="Country"]').value; // Select ID'si yoktu, name'den yakalıyoruz
			const city     = document.getElementById('cityInput').value.trim();
			const startDate = document.getElementById('tourStartInput').value;
			const endDate   = document.getElementById('tourEndInput').value;
			const duration  = document.getElementById('dayNightHidden').value;
			const capacity  = document.getElementById('capacityInput').value;
			const price     = document.getElementById('priceInput').value;

			// Özet alanlarını dolduruyoruz
			document.getElementById('sumTitle').textContent = title || '—';

			// Lokasyon Birleştirme
			let locationText = '—';
			if (country || city) {
				locationText = (country && city) ? country + ' / ' + city : (country || city);
			}
			document.getElementById('sumLocation').textContent = locationText;

			// Tarih Aralığı Formatlama
			if (startDate && endDate) {
				document.getElementById('sumDate').textContent = formatDate(startDate) + ' - ' + formatDate(endDate);
			} else if (startDate) {
				document.getElementById('sumDate').textContent = formatDate(startDate);
			} else {
				document.getElementById('sumDate').textContent = '—';
			}

			document.getElementById('sumDuration').textContent = duration || '—';
			document.getElementById('sumCapacity').textContent = capacity ? capacity + ' People ($' + price + '/pp)' : '—';
		}

		function formatDate(dateStr) {
			if(!dateStr) return '';
			const [y, m, d] = dateStr.split('-');
			return d + '.' + m + '.' + y;
		}

		// Tüm inputlara dinleyici ekle (Özetin anlık değişmesi için)
		const trackInputs = ['tourTitleInput', 'cityInput', 'tourStartInput', 'tourEndInput', 'capacityInput', 'priceInput'];
		trackInputs.forEach(id => {
			const el = document.getElementById(id);
			if (el) el.addEventListener('input', updateSummary);
		});
		// Select için özel dinleyici
		document.querySelector('select[name="Country"]').addEventListener('change', updateSummary);

		// Sayfa ilk açıldığında çalıştır
		updateDuration();
		updateSummary();

		// ── IMAGE URL PREVIEW ─────────────────────────
		const imageUrlInput = document.getElementById('imageUrlInput');
		const urlPreviewImg = document.getElementById('urlPreviewImg');
		let urlDebounce;

		imageUrlInput.addEventListener('input', function () {
			clearTimeout(urlDebounce);
			urlDebounce = setTimeout(function () {
				const url = imageUrlInput.value.trim();
				if (url) {
					urlPreviewImg.src = url;
					urlPreviewImg.style.display = 'block';
					urlPreviewImg.onerror = function () { urlPreviewImg.style.display = 'none'; };
				} else {
					urlPreviewImg.style.display = 'none';
				}
			}, 600);
		});

		// ── FILE UPLOAD PREVIEW ────────────────────────
		const imageFileInput = document.getElementById('imageFileInput');
		const previewBox = document.getElementById('previewBox');
		const previewImg = document.getElementById('previewImg');
		const uploadZone = document.getElementById('uploadZone');

		imageFileInput.addEventListener('change', function () {
			const file = this.files[0];
			if (!file) return;
			const reader = new FileReader();
			reader.onload = function (e) {
				previewImg.src = e.target.result;
				previewBox.style.display = 'block';
				uploadZone.style.display = 'none';
			};
			reader.readAsDataURL(file);
		});

		function removeImage() {
			previewBox.style.display = 'none';
			uploadZone.style.display = 'block';
			imageFileInput.value = '';
			previewImg.src = '';
		}

		// ── STATUS TOGGLE ─────────────────────────────
		function updateStatus(radio) {
			['statusActive','statusDraft','statusPassive'].forEach(id => {
				const el = document.getElementById(id);
				if(el) el.classList.remove('selected-active','selected-draft');
			});
			const parent = radio.closest('.status-option');
			if (radio.value === 'active') parent.classList.add('selected-active');
			else if (radio.value === 'draft') parent.classList.add('selected-draft');
		}

		// ── DRAFT SAVE ────────────────────────────────
		function saveDraft() {
			const radio = document.querySelector('input[name="PublishStatus"][value="draft"]');
			if (radio) { radio.checked = true; updateStatus(radio); }
			document.getElementById('createTourForm').submit();
		}

		// ── SUBMIT FEEDBACK ───────────────────────────
		document.getElementById('createTourForm').addEventListener('submit', function () {
			const btn = document.getElementById('submitBtn');
			btn.disabled = true;
			btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
		});
	</script>
}


}






