								<br />
								<label asp-for="TourEnd" class="field-label">
									<i class="bi bi-calendar-event" style="color:#a0aec0;font-size:.85rem;"></i>
									Tour End Date <span class="required">*</span>
								</label>
								<div class="input-with-icon">
									<i class="bi bi-calendar3 input-icon"></i>
									<input asp-for="TourEnd" type="date" class="form-control" id="tourEndInput"
