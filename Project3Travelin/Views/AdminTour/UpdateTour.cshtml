						<button type="button" class="btn-draft" onclick="saveDraft()">
							<i class="bi bi-floppy"></i>
							Save as Draft
						</button>
						<a asp-action="Index" class="btn-cancel">
							<i class="bi bi-x me-1"></i>Cancel and return
						</a>
