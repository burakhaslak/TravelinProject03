@model List<ResultCommentDto>
@{
	var tours = ViewBag.Tours as List<ResultTourDto>;
}

<section class="trending recent-articles pt-0 pb-6">
	<div class="container">
		<div class="section-title mb-6 w-75 mx-auto text-center">
			<h4 class="mb-1 theme1">Our Blogs Offers</h4>
			<h2 class="mb-1">Recent <span class="theme">Reviews</span></h2>
			<p>Real Stories from Real Travelers.</p>
		</div>
		<div class="recent-articles-inner">

			<div class="row blog-slider slick_arrows">
				@foreach(var item in Model)
				{
					var tour = tours?.FirstOrDefault(x => x.TourId == item.TourId);
					<div class="col-lg-3 col-md-6">
						<div class="trend-item box-shadow bg-white p-2 mb-4 rounded">
							<div class="trend-image rounded">
								
								<img src="@tour.ImageUrl" alt="image" />
							</div>
							<div class="trend-content-main p-2">
								<div class="trend-content">
									<div class="d-flex justify-content-between align-items-center py-1">
										<span class="d-inline-flex align-items-center gap-1 fs-9"> <i class="icon-user theme"></i> By @item.NameSurname </span>
										<span class="d-inline-flex align-items-center gap-1 fs-9"> <i class="icon-calendar theme"></i> @item.CommentDate.ToString("MMM-dd-yyyy") </span>
									</div>
									<h5 class="mb-0"><a href="detail-1.html">@item.Headline</a></h5>
									<div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top border-light">
										<a href="/Tour/TourDetails/@item.TourId" class="nir-btn fs-8 px-3 py-1">Read More</a>
										<span class="d-inline-flex align-items-center theme fs-8 gap-1"><i class="fa fa-star"></i> @item.Score</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				}
			</div>
		</div>
	</div>
</section>