@model List<GetBookingByIdDto>
@{
    ViewData["Title"] = "ActiveParticipantList";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
    // Eğer listede veri varsa tur başlığını oradan alalım
    var tourTitle = Model.FirstOrDefault()?.TourTitle ?? "Tour";
}

<style>
    <style >
    /* Tablo Kartı Tasarımı */
    .table-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: 1px solid #eef2f7;
        overflow: hidden;
        margin-top: 20px;
    }

    .table-card-header {
        padding: 20px 25px;
        background: #f8fafc;
        border-bottom: 1px solid #eef2f7;
    }

        .table-card-header .title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .tour-count {
        font-size: 0.8rem;
        background: #e2e8f0;
        color: #64748b;
        padding: 2px 10px;
        border-radius: 20px;
        margin-left: 10px;
    }

    /* Tablo Stilleri */
    .tours-table {
        width: 100%;
        border-collapse: collapse;
        vertical-align: middle;
    }

        .tours-table therapeutic {
            background-color: #f8fafc;
        }

        .tours-table th {
            padding: 15px 25px;
            text-align: left;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.025em;
            color: #64748b;
            font-weight: 600;
            border-bottom: 2px solid #eef2f7;
        }

        .tours-table td {
            padding: 18px 25px;
            font-size: 0.95rem;
            color: #1e293b;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .tours-table tr:hover {
            background-color: #fcfcfd;
        }

    /* Avatar ve Müşteri Bilgisi */
    .admin-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #6366f1;
        color: white;
        font-weight: bold;
        border-radius: 8px;
    }

    /* Hücre Detayları */
    .date-cell {
        color: #475569;
        font-weight: 500;
        display: block;
    }

    .cap-cell {
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Buton Grupları */
    .action-group {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-detail:hover {
        background: #dcfce7 !important;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fecaca;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: #e0f2fe;
        color: #0284c7;
    }

        .btn-edit:hover {
            background: #bae6fd;
            transform: translateY(-2px);
        }

    /* Badge Düzenlemeleri */
    .badge {
        letter-spacing: 0.5px;
        border: none;
    }

    /* Mevcut stilleriniz kalabilir, ek olarak: */
    .tour-highlight-header {
        background: #6366f1;
        color: white;
        padding: 1.5rem;
        border-radius: 12px;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.2);
    }
    .empty-state {
        padding: 50px;
        text-align: center;
        color: #718096;
    }
</style>

<div class="page-header">
    <div>
        <h1 class="page-title">Participants for Tour</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/AdminTour/TourList">Tours</a></li>
                <li class="breadcrumb-item active">Participant List</li>
            </ol>
        </nav>
    </div>
</div>

<div class="tour-highlight-header">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <span style="font-size: 0.8rem; text-transform: uppercase; opacity: 0.8;">Currently Viewing Participants for:</span>
            <h3 class="mb-0 fw-bold">@tourTitle</h3>
        </div>
        <div class="text-end">
            <h2 class="mb-0 fw-bold">@Model.Sum(x => x.PersonCount)</h2>
            <span style="font-size: 0.8rem; opacity: 0.8;">Total Persons</span>
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <div class="title">
            <i class="bi bi-people-fill" style="color:#6366f1;"></i>
            Confirmed Participants
            <span class="tour-count">@Model.Count bookings</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="tours-table">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Contact Info</th>
                    <th>Booking Date</th>
                    <th>Person Count</th>
                    <th>Status</th>
                    <th class="text-end">Quick Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <i class="bi bi-folder-x" style="font-size: 2rem; display: block;"></i>
                            No active participants found for this tour.
                        </td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="admin-avatar" style="width:35px; height:35px;">
                                    @item.NameSurname.Substring(0, 1).ToUpper()
                                </div>
                                <div class="fw-bold">@item.NameSurname</div>
                            </div>
                        </td>
                        <td>
                            <div style="font-size:.85rem;">
                                <i class="bi bi-envelope text-muted"></i> @item.Mail <br />
                                <i class="bi bi-telephone text-muted"></i> @item.Phone
                            </div>
                        </td>
                        <td><span class="date-cell">@item.BookingDate.ToString("dd MMM yyyy HH:mm")</span></td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="bi bi-people me-1"></i> @item.PersonCount
                            </span>
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge rounded-pill bg-warning text-dark">PENDING</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge rounded-pill bg-success">APPROVED</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger">@item.Status.ToUpper()</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="action-group justify-content-end">
                                <a href="mailto:@item.Mail" class="btn-action btn-edit" title="Send Email">
                                    <i class="bi bi-envelope"></i>
                                </a>
                                <a href="tel:@item.Phone" class="btn-action btn-detail" title="Call">
                                    <i class="bi bi-telephone"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>