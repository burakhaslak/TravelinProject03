@model List<ResultBookingDto>
@{
    ViewData["Title"] = "BookingList";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
}

<style>
    /* Tablo Kartı Tasarımı */
    .table-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        border: 1px solid #eef2f7;
        overflow: hidden;
        margin-top: 20px;
    }

    .table-card-header {
        padding: 20px 25px;
        background: #f8fafc;
        border-bottom: 1px solid #eef2f7;
    }

        .table-card-header .title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .tour-count {
        font-size: 0.8rem;
        background: #e2e8f0;
        color: #64748b;
        padding: 2px 10px;
        border-radius: 20px;
        margin-left: 10px;
    }

    /* Tablo Stilleri */
    .tours-table {
        width: 100%;
        border-collapse: collapse;
        vertical-align: middle;
    }

        .tours-table therapeutic {
            background-color: #f8fafc;
        }

        .tours-table th {
            padding: 15px 25px;
            text-align: left;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.025em;
            color: #64748b;
            font-weight: 600;
            border-bottom: 2px solid #eef2f7;
        }

        .tours-table td {
            padding: 18px 25px;
            font-size: 0.95rem;
            color: #1e293b;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .tours-table tr:hover {
            background-color: #fcfcfd;
        }

    /* Avatar ve Müşteri Bilgisi */
    .admin-avatar {
        display: flex;
        align-items: center;
        justify-content: center;
        background: #6366f1;
        color: white;
        font-weight: bold;
        border-radius: 8px;
    }

    /* Hücre Detayları */
    .date-cell {
        color: #475569;
        font-weight: 500;
        display: block;
    }

    .cap-cell {
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    /* Buton Grupları */
    .action-group {
        display: flex;
        gap: 8px;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-detail:hover {
        background: #dcfce7 !important;
        transform: translateY(-2px);
    }

    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-delete:hover {
            background: #fecaca;
            transform: translateY(-2px);
        }

    .btn-edit {
        background: #e0f2fe;
        color: #0284c7;
    }

        .btn-edit:hover {
            background: #bae6fd;
            transform: translateY(-2px);
        }

    /* Badge Düzenlemeleri */
    .badge {
        letter-spacing: 0.5px;
        border: none;
    }
</style>
<div class="page-header">
    <div>
        <h1 class="page-title">Booking Requests</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Bookings</li>
            </ol>
        </nav>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <div class="title">
            <i class="bi bi-calendar2-check" style="color:#a0aec0;"></i>
            Incoming Requests
            <span class="tour-count">@Model.Count total</span>
        </div>
    </div>

    <div class="table-responsive">
        <table class="tours-table">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Tour</th>
                    <th>Date</th>
                    <th>Persons</th>
                    <th>Total Price</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="admin-avatar" style="width:30px; height:30px; font-size:.7rem;">
                                    @item.NameSurname.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-bold">@item.NameSurname</div>
                                    <div style="font-size:.75rem; color:#718096;">@item.Mail</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="fw-medium">@item.TourTitle</span></td>
                        <td><span class="date-cell">@item.BookingDate.ToString("dd.MM.yyyy HH:mm")</span></td>
                        <td><span class="cap-cell"><i class="bi bi-people"></i> @item.PersonCount</span></td>
                        <td><span class="fw-bold text-primary">€@item.TotalPrice</span></td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge rounded-pill bg-warning text-dark" style="font-size:.7rem; font-weight:600; padding:.35rem .65rem;">PENDING</span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge rounded-pill bg-success" style="font-size:.7rem; font-weight:600; padding:.35rem .65rem;">APPROVED</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-danger" style="font-size:.7rem; font-weight:600; padding:.35rem .65rem;">CANCELLED</span>
                            }
                        </td>
                        <td class="text-end">
                            @Html.AntiForgeryToken()
                            <div class="action-group justify-content-end">
                                @if (item.Status == "Pending")
                                {
                                    <button onclick="approveBooking('@item.BookingId')" class="btn-action btn-detail" title="Approve" style="background:#f0fdf4; color:#16a34a;">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button onclick="cancelBooking('@item.BookingId')" class="btn-action btn-delete" title="Reject">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                }
                                <a href="mailto:@item.Mail" class="btn-action btn-edit" title="Send Direct Email">
                                    <i class="bi bi-envelope"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<script>
    function approveBooking(id) {
        fetch('/AdminBooking/ApproveBooking/' + id, {
            method: 'POST',
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        }).then(() => location.reload());
    }
        function approveBooking(id) {
        fetch('/AdminBooking/ApproveBooking/' + id, {
            method: 'POST'
        }).then(() => location.reload());
    }

    function cancelBooking(id) {
        fetch('/AdminBooking/CancelBooking/' + id, {
            method: 'POST'
        }).then(() => location.reload());
    }
</script>