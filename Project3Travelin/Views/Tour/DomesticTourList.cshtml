@model List<ResultTourDto>

@{
	Layout = null;
}

<!DOCTYPE html>


@await Component.InvokeAsync("_TourHeadComponentPartial")
<!-- Preloader -->
<!-- Preloader Ends -->
<!-- header starts -->
<header class="main_header_area">
	<div class="header-content py-1 bg-theme">
		<div class="container d-flex align-items-center justify-content-between">
			<div class="links">
				<ul>
					<li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
					<li><a href="#" class="white"><i class="icon-location-pin white"></i>  Istanbul, Turkiye</a></li>
					<li><a href="#" class="white"><i class="icon-clock white"></i> Mon-Sat: 08.30-18.00</a></li>
				</ul>
			</div>
			<div class="links float-right">
				<ul>
					<li><a href="#" class="white"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
					<li><a href="#" class="white"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
					<li><a href="#" class="white"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
					<li><a href="#" class="white"><i class="fab fa-linkedin " aria-hidden="true"></i></a></li>
				</ul>
			</div>
		</div>
	</div>
	<div class="header_menu" id="header_menu">
		<nav class="navbar navbar-default">
			<div class="container">
				<div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
					<div class="navbar-header">
						<a class="navbar-brand" href="index.html">
							<img src="/travelin/images/logo.png" alt="image">
						</a>
					</div>
					<div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
						<ul class="nav navbar-nav" id="responsive-menu">

							<li><a href="/HomePage/Home/">Home</a></li>
							<li><a href="/Tour/TourList/">Tour List</a></li>
							<li><a href="/Tour/VisaFreeTourList/">No Visa Tours</a></li>
							<li><a href="/Tour/DomesticTourList/">Domestic Tours</a></li>


							<li class="search-main"><a href="#search1" class="mt_search"><i class="fa fa-search"></i></a></li>
						</ul>
					</div><div class="register-login d-flex align-items-center">
						<a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="me-3">
							<i class="icon-user"></i> LOGIN / REGISTER
						</a>
						<a href="booking.html" class="nir-btn white">Book Now</a>
					</div>

					<div id="slicknav-mobile"></div>
				</div>
			</div>
		</nav>
	</div>
</header>

<section class="breadcrumb-main pb-20 pt-14" style="background-image: url(https://images8.alphacoders.com/685/thumb-1920-685420.jpg);">
	<div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
	<div class="breadcrumb-outer">
		<div class="container">
			<div class="breadcrumb-content text-center">
				<h1 class="mb-3">Domestic Tours</h1>
				<nav aria-label="breadcrumb" class="d-block">
					<ul class="breadcrumb">
						<li class="breadcrumb-item"><a href="#">Home</a></li>
						<li class="breadcrumb-item active" aria-current="page">Domestic List</li>
					</ul>
				</nav>
			</div>
		</div>
	</div>
	<div class="dot-overlay"></div>
</section>

<!-- header ends -->
<!-- BreadCrumb Starts -->
<!-- BreadCrumb Ends -->
<!-- top Destination starts -->

<section class="trending pt-6 pb-0 bg-lgrey">
	<div class="container">
		<div class="list-results d-flex align-items-center justify-content-between">
			<div class="list-results-sort">
 				<p class="m-0">Showing @((ViewBag.CurrentPage - 1) * ViewBag.PageSize + 1)-@((int)ViewBag.CurrentPage * (int)ViewBag.PageSize) results</p>
 		</div>
			<div class="click-menu d-flex align-items-center justify-content-between">
				<div class="change-list f-active me-2"><a href="tour-list.html"><i class="fa fa-bars rounded"></i></a></div>
				<div class="change-grid me-2"><a href="tour-grid.html"><i class="fa fa-th rounded"></i></a></div>
				<div class="sortby d-flex align-items-center justify-content-between ml-2">
					<select class="niceSelect">
						<option value="1">Sort By</option>
						<option value="2">Average rating</option>
						<option value="3">Price: low to high</option>
						<option value="4">Price: high to low</option>
					</select>
				</div>
			</div>
		</div>

		<div class="destination-list">
			@foreach (var item in Model)
			{
				<div class="trend-full bg-white rounded box-shadow overflow-hidden p-4 mb-4">
					<div class="row">
						<div class="col-lg-4 col-md-3">
							<div class="trend-item2 rounded">
								<a href="tour-single.html" style="background-image: url(@item.ImageUrl);"></a>
								<div class="color-overlay"></div>
							</div>
						</div>
						<div class="col-lg-5 col-md-6">
							<div class="trend-content position-relative text-md-start text-center">
								<small>@item.DayNight</small>
								<h3 class="mb-1"><a href="tour-single.html">@item.Title</a></h3>
								<h6 class="theme mb-0"><i class="icon-location-pin"></i> @item.Country</h6>
								<p class="mt-4 mb-0">@item.Description<br><a href="#"><span class="theme"> Free cancellation</span></a></p>
							</div>
						</div>
						<div class="col-lg-3 col-md-3">
							<div class="trend-content text-md-end text-center">
								<div class="rating mb-1">
									@for (int i = 1; i <= 5; i++)
									{
										<i class="fa fa-star" style="color: @(i <= Math.Round(item.AverageScore) ? "#ffc107" : "#ccc"); font-size:13px;"></i>
									}
								</div>
								@if (item.ReviewCount > 0)
								{
									<small>@item.AverageScore.ToString("0.0") (@item.ReviewCount Reviews)</small>
								}
								else
								{
									<small>No reviews yet</small>
								}
								<div class="trend-price my-2">
									<span class="mb-0">From</span>
									<h3 class="mb-0">€ @item.Price</h3>
									<small>Per Person</small>
								</div>
								<a href="/Tour/TourDetails/@item.TourId" class="nir-btn">View Detail</a>
							</div>
						</div>
					</div>
				</div>
			}
			<div class="text-center mt-4">
				@if (ViewBag.CurrentPage > 1)
				{
					<a href="?page=@(ViewBag.CurrentPage - 1)" class="nir-btn me-2">
						<i class="fa fa-long-arrow-alt-left"></i> Prev
					</a>
				}

				@for (int i = 1; i <= ViewBag.TotalPages; i++)
				{
					<a href="?page=@i" class="nir-btn me-1 @(i == ViewBag.CurrentPage ? "active" : "")">@i</a>
				}

				@if (ViewBag.CurrentPage < ViewBag.TotalPages)
				{
					<a href="?page=@(ViewBag.CurrentPage + 1)" class="nir-btn ms-2">
						Next <i class="fa fa-long-arrow-alt-right"></i>
					</a>
				}
			</div>
		</div>
	</div>
</section>


<!-- top Destination ends -->
<!-- Discount action starts -->
<!-- Discount action Ends -->
<!-- partner starts -->
<!-- partner ends -->
