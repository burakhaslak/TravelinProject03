@model TourDetailViewModel
@{
	Layout = null;
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="zxx">

<head>

	<style>
		/* Gri ekran donmasını engelleyen mucize kod */
		.modal-backdrop {
			display: none !important; /* Arka planı tamamen kapat, donma bitsin */
		}

		#bookingModal {
			background: rgba(0,0,0,0.5); /* Kendi transparan arka planımızı yapalım */
			z-index: 99999 !important;
		}

		.modal-content {
			z-index: 100000 !important;
		}
	</style>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>Travelin - Travel Tour Booking HTML Templates</title>
	<!-- Favicon -->
	<link rel="shortcut icon" type="image/x-icon" href="/travelin/images/favicon.png">
	<!-- Bootstrap core CSS -->
	<link href="/travelin/css/bootstrap.min.css" rel="stylesheet" type="text/css">
	<!--Custom CSS-->
	<link href="/travelin/css/style.css" rel="stylesheet" type="text/css">
	<!--Plugin CSS-->
	<link href="/travelin/css/plugin.css" rel="stylesheet" type="text/css">

	<!--Font Awesome-->

	<link rel="stylesheet" href="/travelin/css/fontawesome.min.css" />

	<link rel="stylesheet" href="/travelin/fonts/line-icons.css" type="text/css">
	<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
	<!-- Preloader -->
	<div id="preloader">
		<div id="status"></div>
	</div>
	<!-- Preloader Ends -->
	<!-- header starts -->
	<header class="main_header_area">
		<div class="header-content py-1 bg-theme">
			<div class="container d-flex align-items-center justify-content-between">
				<div class="links">
					<ul>
						<li><a href="#" class="white"><i class="icon-calendar white"></i> @DateTime.Now.Year</a></li>
						<li><a href="#" class="white"><i class="icon-location-pin white"></i>  Istanbul, Turkiye</a></li>
						<li><a href="#" class="white"><i class="icon-clock white"></i> Mon-Sat: 08.30-18.00</a></li>
					</ul>
				</div>
				<div class="links float-right">
					<ul>
						<li><a href="#" class="white"><i class="fab fa-facebook" aria-hidden="true"></i></a></li>
						<li><a href="#" class="white"><i class="fab fa-twitter" aria-hidden="true"></i></a></li>
						<li><a href="#" class="white"><i class="fab fa-instagram" aria-hidden="true"></i></a></li>
						<li><a href="#" class="white"><i class="fab fa-linkedin " aria-hidden="true"></i></a></li>
					</ul>
				</div>
			</div>
		</div>
		<div class="header_menu" id="header_menu">
			<nav class="navbar navbar-default">
				<div class="container">
					<div class="navbar-flex d-flex align-items-center justify-content-between w-100 pb-3 pt-3">
						<div class="navbar-header">
							<a class="navbar-brand" href="index.html">
								<img src="/travelin/images/logo.png" alt="image">
							</a>
						</div>
						<div class="navbar-collapse1 d-flex align-items-center" id="bs-example-navbar-collapse-1">
							<ul class="nav navbar-nav" id="responsive-menu">

								<li><a href="/HomePage/Home/">Home</a></li>
								<li><a href="/Tour/TourList/">Tour List</a></li>
								<li><a href="/Tour/VisaFreeTourList/">No Visa Tours</a></li>
								<li><a href="/Tour/DomesticTourList/">Domestic Tours</a></li>


								<li class="search-main"><a href="#search1" class="mt_search"><i class="fa fa-search"></i></a></li>
							</ul>
						</div><div class="register-login d-flex align-items-center">
							<a href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" class="me-3">
								<i class="icon-user"></i> LOGIN / REGISTER
							</a>
							<a href="booking.html" class="nir-btn white">Book Now</a>
						</div>

						<div id="slicknav-mobile"></div>
					</div>
				</div>
			</nav>
		</div>
	</header>

	<!-- header ends -->
	<!-- banner starts -->
	<div class="banner trending overflow-hidden">
		<div class="section-shape section-shape1 top-inherit bottom-0" style="background-image: url(/travelin/images/shape8.png);"></div>
		<div class="banner-slide">
			<div class="single-banner-image">
				<div class="trend-item1 box-shadow bg-white text-center">
					<div class="trend-image position-relative">
						<img src="@Model.TourDetails.VerticalImageUrl" alt="image" class="w-100" style="max-height: 500px; object-fit: cover;">
						<div class="overlay"></div>
					</div>
				</div>
			</div>
		</div>
		<div class="banner-breadcrum position-absolute top-50 mx-auto w-50 start-50 text-center translate-middle">
			<div class="breadcrumb-content text-center">
				<h1 class="mb-0 white">Tour Detail</h1>
				<nav aria-label="breadcrumb" class="d-block">
					<ul class="breadcrumb">
						<li class="breadcrumb-item"><a href="#">Home</a></li>
						<li class="breadcrumb-item active" aria-current="page">Tour Single</li>
					</ul>
				</nav>
			</div>
		</div>
	</div>
	<!-- banner ends -->
	<!-- top Destination starts -->
	<section class="trending pt-6 pb-0 bg-lgrey">
		<div class="container">
			<div class="row">
				<div class="col-lg-8">
					<div class="single-content">
						<div id="highlight">
							<div class="single-full-title border-b mb-2 pb-2">
								<div class="single-title">
									<h2 class="mb-1">@Model.TourDetails.Title</h2>
									<div class="rating-main d-md-flex align-items-center">
										<p class="mb-0 me-2"><i class="icon-location-pin"></i> @Model.TourDetails.City, @Model.TourDetails.Country</p>
										@if (Model.ReviewCount > 0)
										{
											<div class="d-flex align-items-center">
												@for (int i = 1; i <= 5; i++)
												{
													<i class="fa fa-star" style="color: @(i <= Math.Round(Model.AverageScore) ? "#ffc107" : "#ccc");"></i>
												}
												<span class="ms-2">@Model.AverageScore.ToString("0.0") (@Model.ReviewCount Reviews)</span>
											</div>
										}
										else
										{
											<span>(No reviews yet)</span>
										}
									</div>

								</div>
							</div>
						</div>

						<div class="description-images mb-4">
							<img src="@Model.TourDetails.ImageUrl" alt="" class="w-100 rounded">
						</div>

						<div class="description mb-2">
							<h4>Description</h4>
							<p>@Model.TourDetails.DetailedDescription</p>
						</div>

						<div class="tour-includes mb-4">
							<table class="table-borderless w-100">
								<tbody>
									<tr>
										<td><i class="fa fa-hourglass-half pink mr-1" aria-hidden="true"></i>@Model.TourDetails.DayNight</td>

										<td><i class="fa fa-users pink mr-1" aria-hidden="true"></i> Max People: @Model.TourDetails.Capacity</td>

										<td><i class="fa fa-calendar-check-o pink mr-1" aria-hidden="true"></i> @Model.TourDetails.TourStart.ToString("MMM dd") - @Model.TourDetails.TourEnd.ToString("MMM dd") </td>
									</tr>
									<tr>
										<td><i class="fa fa-globe pink mr-1" aria-hidden="true"></i> @Model.TourDetails.Continent </td>

										<td><i class="fa fa-tag pink mr-1" aria-hidden="true"></i> Price: € @Model.TourDetails.Price</td>

										<td><i class="fa fa-language pink mr-1" aria-hidden="true"></i> Language: English</td>
									</tr>
								</tbody>
							</table>
						</div>



						<div class="description mb-4">
							<h4>What to Expect</h4>
							<p>@Model.TourDetails.WhattoExpect</p>
						</div>
					</div>

					@await Component.InvokeAsync("_TourDailyPlanComponentPartial", new { id = Model.TourDetails.TourId })

					<div id="single-map" class="single-map mb-4">
						<h4>Tour View</h4>
						<div class="map rounded overflow-hidden">
							<div style="width: 100%">
								<img src="@Model.TourDetails.MapUrl"
									 alt="Tour View"
									 class="rounded"
									 style="width: 100%; height: auto; min-height: 500px; max-height: 800px; object-fit: contain; display: block; background-color: #f0f2f5;" />
							</div>
						</div>
					</div>



					<!-- blog comment list -->
					@await Component.InvokeAsync("_SentTourCommentsComponentPartial", new { id = Model.TourDetails.TourId })


					@await Html.PartialAsync("~/Views/Comment/ShareComment.cshtml", Model.TourDetails.TourId)

				</div>

				<div class="col-lg-4 ps-lg-4">
					<div class="sidebar-sticky sticky1">
						<div class="tabs-navbar bg-lgrey mb-4 bordernone rounded overflow-hidden">
							<div class="row">
								<div class="col-md-12">
									<ul id="tabs" class="nav nav-tabs bordernone mb-0">
										<li><a data-toggle="tab" href="#highlight" class="rounded box-shadow mb-2 border-all">Highlight</a></li>
										<li><a data-toggle="tab" href="#iternary" class="rounded box-shadow mb-2 border-all">Iternary</a></li>
										<li><a data-toggle="tab" href="#single-map" class="rounded box-shadow mb-2 border-all">Map</a></li>
										<li><a data-toggle="tab" href="#single-comments" class="rounded box-shadow mb-2 border-all">Comments</a></li>
										<li><a data-toggle="tab" href="#single-add-review" class="rounded box-shadow mb-2 border-all">Add Reviews</a></li>
										<li class="w-100 mt-2">
											<button type="button" class="nir-btn white w-100" data-bs-toggle="modal" data-bs-target="#bookingModal">
												Book Now
											</button>
									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
				<div class="modal-dialog modal-dialog-centered">
					<div class="modal-content" style="border-radius:15px; border:none; box-shadow: 0 15px 50px rgba(0,0,0,0.2);">
						<div class="modal-header bg-theme p-4">
							<h5 class="modal-title white">Reservation for @Model.TourDetails.Title</h5>
							<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
						</div>
						<form id="bookingForm" asp-action="MakeReservation" asp-controller="AdminBooking" method="post">
							@* Anti-forgery token güvenliği için *@
							@Html.AntiForgeryToken()

							@* Name değerlerini direkt DTO'ndaki property isimleriyle aynı yapıyoruz *@
							<input type="hidden" name="TourId" value="@Model.TourDetails.TourId" />
							<input type="hidden" id="unitPrice" name="UnitPrice" value="@Model.TourDetails.Price" />

							<div class="modal-body p-4">
								<div class="mb-3">
									<label class="form-label fw-bold text-dark">Full Name</label>
									<input type="text" name="NameSurname" class="form-control" placeholder="Enter your full name" required />
								</div>
								<div class="mb-3">
									<label class="form-label fw-bold text-dark">Email Address</label>
									<input type="email" name="Mail" class="form-control" placeholder="example@mail.com" required />
								</div>
								<div class="mb-3">
									<label class="form-label fw-bold text-dark">Phone Number</label>
									<input type="tel" name="Phone" class="form-control" placeholder="05XX XXX XX XX" required />
								</div>
								<div class="row align-items-center">
									<div class="col-6">
										<label class="form-label fw-bold text-dark">Person Count</label>
										<input type="number" id="personCount" name="PersonCount" class="form-control" value="1" min="1" oninput="calculateTotal()" />
									</div>
									<div class="col-6 text-end">
										<span class="d-block text-muted small">Total Price</span>
										<h3 class="theme1 mb-0" id="displayTotal">€@Model.TourDetails.Price</h3>
									</div>
								</div>
							</div>
							<div class="modal-footer border-0 p-4">
								<button type="submit" class="nir-btn white w-100">Confirm Booking</button>
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!-- top Destination ends -->
	<!-- Discount action starts -->
	<section class="discount-action pt-0" style="background-image:url(/travelin/images/section-bg1.png); background-position:center;">
		<div class="container">
			<div class="call-banner rounded pt-10 pb-14">
				<div class="call-banner-inner w-75 mx-auto text-center px-5">
					<div class="trend-content-main">
						<div class="trend-content mb-5 pb-2 px-5">
							<h5 class="mb-1 theme">Love Where Your're Going</h5>
							<h2><a href="detail-fullwidth.html">Explore Your Life, <span class="theme1"> Travel Where You Want!</span></a></h2>
							<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
						</div>
						<div class="video-button text-center position-relative">
							<div class="call-button text-center">
								<button type="button" class="play-btn js-video-button" data-video-id="152879427" data-channel="vimeo">
									<i class="fa fa-play bg-blue"></i>
								</button>
							</div>
							<div class="video-figure"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="white-overlay"></div>
		<div class="white-overlay"></div>
		<div class="section-shape  top-inherit bottom-0" style="background-image: url(/travelin/images/shape6.png);"></div>
	</section>
	<!-- Discount action Ends -->
	<!-- partner starts -->
	<!-- partner ends -->
	<!-- footer starts -->
	@await Component.InvokeAsync("_TourFooterComponentPartial")
	<!-- footer ends -->
	<!-- Back to top start -->
	<div id="back-to-top">
		<a href="#"></a>
	</div>
	<!-- Back to top ends -->
	<!-- search popup -->
	<div id="search1">
		<button type="button" class="close">×</button>
		<form>
			<input type="search" value="" placeholder="type keyword(s) here" />
			<button type="submit" class="btn btn-primary">Search</button>
		</form>
	</div>

	<!-- login registration modal -->
	<!-- *Scripts* -->
	<script src="/travelin/js/jquery-3.5.1.min.js"></script>
	<script src="/travelin/js/bootstrap.min.js"></script>
	<script src="/travelin/js/fontawesome.min.js"></script>
	<script src="/travelin/js/particles.js"></script>
	<script src="/travelin/js/particlerun.js"></script>
	<script src="/travelin/js/plugin.js"></script>
	<script src="/travelin/js/main.js"></script>
	<script src="/travelin/js/custom-accordian.js"></script>
	<script src="/travelin/js/custom-nav.js"></script>

	<script>
		function calculateTotal() {
			// ID'leri yukarıdaki formla eşledik
			const unitPrice = parseFloat($('#unitPrice').val());
			const personCount = parseInt($('#personCount').val()) || 1;
			const total = unitPrice * personCount;
			$('#displayTotal').text("€" + total.toFixed(2));
		}

				$(document).ready(function () {
			$('#bookingForm').on('submit', function (e) {
				e.preventDefault();

				const url = $(this).attr('action');
				const formData = $(this).serialize();

				// Yükleniyor animasyonu göster (Opsiyonel ama profesyonel gösterir)
				Swal.fire({
					title: 'Processing...',
					text: 'Please wait while we register your booking.',
					allowOutsideClick: false,
					didOpen: () => { Swal.showLoading(); }
				});

				$.post(url, formData, function (result) {
					if (result.success) {
						// Modal'ı kapat
						$('#bookingModal').modal('hide');

						// Başarılı Pop-up
						Swal.fire({
							icon: 'success',
							title: 'Booking Received!',
							html: `
								<p>Thank you, <b>${$("input[name='NameSurname']").val()}</b>!</p>
								<p>Your reservation request for this tour has been successfully sent.
								Our team will review your request and contact you for <b>final approval</b> soon.</p>
							`,
							confirmButtonText: 'Great!',
							confirmButtonColor: '#ff4838', // Sitenizin ana rengine göre ayarlayabilirsiniz
						}).then((result) => {
							if (result.isConfirmed) {
								location.reload(); // Sayfayı yenile
							}
						});
					} else {
						// Hata Pop-up
						Swal.fire({
							icon: 'error',
							title: 'Oops...',
							text: result.message || 'Something went wrong!',
							confirmButtonColor: '#d33'
						});
					}
				}).fail(function() {
					Swal.fire({
						icon: 'error',
						title: 'Connection Error',
						text: 'Could not reach the server. Please try again later.',
						confirmButtonColor: '#d33'
					});
				});
			});
		});
	</script>

</body>
</html>




