@model List<ResultCommentDto>
@{
    ViewData["Title"] = "Review List";
    Layout = "~/Views/Shared/_TourLayout.cshtml";
    string q = Context.Request.Query["q"];
    string status = Context.Request.Query["status"];
    string tourFilter = Context.Request.Query["tour"];
}



@section Styles {
    <style>
        .page-header, .page-header * { font-family: 'Inter', sans-serif !important; }
        .page-header { display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
        .page-title { font-size: 1.6rem; font-weight: 800; color: #1a202c; letter-spacing: -.03em; line-height: 1; }
        .breadcrumb { margin: 0; padding: 0; background: none; }
        .breadcrumb-item { font-size: .8rem; }
        .breadcrumb-item a { color: #2563eb; text-decoration: none; }
        .breadcrumb-item.active { color: #718096; }

        .table-card {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .table-card-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1.1rem 1.5rem; border-bottom: 1px solid #e2e8f0;
            flex-wrap: wrap; gap: .75rem;
        }

        .table-card-header .title {
            font-weight: 700; font-size: .95rem; color: #1a202c;
            display: flex; align-items: center; gap: .5rem;
        }

        .review-count {
            background: #eff6ff; color: #2563eb;
            font-size: .72rem; font-weight: 600;
            padding: .2rem .6rem; border-radius: 20px;
        }

        .reviews-table { width: 100%; border-collapse: collapse; }

        .reviews-table thead th {
            background: #f8fafc; font-size: .72rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: .06em; color: #718096;
            padding: .85rem 1rem; border-bottom: 1px solid #e2e8f0; white-space: nowrap;
        }

        .reviews-table tbody tr { transition: background .12s; border-bottom: 1px solid #f0f4f8; }
        .reviews-table tbody tr:last-child { border-bottom: none; }
        .reviews-table tbody tr:hover { background: #f8fafc; }
        .reviews-table tbody td { padding: .85rem 1rem; vertical-align: middle; font-size: .875rem; color: #2d3748; }

        .reviewer-info { display: flex; align-items: center; gap: .65rem; }

        .reviewer-avatar {
            width: 38px; height: 38px; border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: grid; place-items: center;
            color: #fff; font-size: .8rem; font-weight: 700; flex-shrink: 0;
        }

        .reviewer-name { font-weight: 600; color: #1a202c; font-size: .875rem; }
        .reviewer-email { font-size: .75rem; color: #a0aec0; }

        .star-display { display: flex; align-items: center; gap: 2px; }
        .star-display i { font-size: .8rem; }

        .score-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            font-size: .78rem; font-weight: 600; padding: .2rem .6rem; border-radius: 20px;
        }
        .score-5, .score-4 { background: #f0fdf4; color: #16a34a; }
        .score-3 { background: #fefce8; color: #ca8a04; }
        .score-2 { background: #fff7ed; color: #ea580c; }
        .score-1 { background: #fff5f5; color: #e53e3e; }

        .tour-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            background: #eff6ff; color: #2563eb;
            font-size: .75rem; font-weight: 500;
            padding: .25rem .6rem; border-radius: 6px;
        }

        .date-cell { font-size: .82rem; font-weight: 500; color: #2d3748; white-space: nowrap; }

        .action-group {
            display: flex; align-items: center;
            justify-content: flex-end;
            gap: .5rem; min-width: 90px;
        }

        .btn-action {
            width: 36px; height: 36px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            border: none; cursor: pointer; font-size: 1rem;
            transition: all .15s; text-decoration: none; flex-shrink: 0;
        }

        .btn-edit { background: #fffbeb; color: #d97706; }
        .btn-edit:hover { background: #fde68a; color: #92400e; }
        .btn-delete { background: #fff5f5; color: #e53e3e; }
        .btn-delete:hover { background: #fed7d7; color: #c53030; }

        .pagination-wrapper {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 1.5rem; border-top: 1px solid #e2e8f0; flex-wrap: wrap; gap: .75rem;
        }
        .page-info { font-size: .8rem; color: #718096; }
        .pagination { margin: 0; }
        .page-link {
            border-radius: 8px !important; border: 1px solid #e2e8f0;
            color: #4a5568; font-size: .8rem; font-weight: 500;
            padding: .35rem .65rem; margin: 0 2px; transition: all .12s;
        }
        .page-link:hover { background: #f7fafc; border-color: #cbd5e0; color: #1a202c; }
        .page-item.active .page-link { background: #2563eb; border-color: #2563eb; color: #fff; }

        .empty-state { padding: 4rem 2rem; text-align: center; color: #a0aec0; }
        .empty-state i { font-size: 3rem; margin-bottom: 1rem; display: block; }
        .empty-state p { font-size: .9rem; }

        @@media (max-width: 991px) {
            .reviews-table thead { display: none; }
            .reviews-table tbody tr {
                display: flex; flex-wrap: wrap; padding: 1rem;
                border: 1px solid #e2e8f0; border-radius: 10px;
                margin: .75rem 1rem; gap: .5rem;
            }
            .reviews-table tbody td {
                display: flex; align-items: center; gap: .5rem;
                padding: .3rem 0; border: none; width: 100%; font-size: .85rem;
            }
            .reviews-table tbody td::before {
                content: attr(data-label); font-size: .7rem; font-weight: 600;
                text-transform: uppercase; letter-spacing: .05em; color: #a0aec0;
                min-width: 90px; flex-shrink: 0;
            }
            .action-group { width: 100%; justify-content: flex-end; }
        }
    </style>
}

<div class="page-header">
    <div>
        <h1 class="page-title">Review List</h1>
        <nav aria-label="breadcrumb" class="mt-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active">Reviews</li>
            </ol>
        </nav>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <div class="title">
            <i class="bi bi-chat-square-text" style="color:#a0aec0;"></i>
            All Reviews
            <span class="review-count">@Model?.Count reviews</span>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-chat-square"></i>
            <p>No reviews found.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="reviews-table">
                <thead>
                    <tr>
                        <th>Reviewer</th>
                        <th>Tour</th>
                        <th>Score</th>
                        <th>Review</th>
                        <th>Date</th>
                        <th style="min-width:90px; text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td data-label="Reviewer">
                                <div class="reviewer-info">
                                    <div class="reviewer-avatar">
                                        @(item.NameSurname?.Length > 0 ? item.NameSurname[0].ToString().ToUpper() : "?")
                                    </div>
                                    <div>
                                        <div class="reviewer-name">@item.NameSurname</div>
                                        <div class="reviewer-email">@item.Mail</div>
                                    </div>
                                </div>
                            </td>
                            <td data-label="Tour">
                                <span class="tour-badge">
                                    <i class="bi bi-map"></i>
                                    @item.TourTitle
                                </span>
                            </td>
                            <td data-label="Score">
                                <div class="star-display mb-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa fa-star" style="color: @(i <= item.Score ? "#ffc107" : "#e2e8f0");"></i>
                                    }
                                </div>
                                <span class="score-badge score-@item.Score">@item.Score / 5</span>
                            </td>
                            <td data-label="Review">
                                <div style="max-width:280px;">
                                    <div style="font-size:.82rem; font-weight:600; color:#1a202c; margin-bottom:3px;">
                                        @((item.Headline?.Length > 30) ? item.Headline.Substring(0, 30) + "…" : item.Headline)
                                    </div>
                                    <div style="font-size:.78rem; color:#718096;">
                                        @((item.CommentDetail?.Length > 50) ? item.CommentDetail.Substring(0, 50) + "…" : item.CommentDetail)
                                    </div>
                                </div>
                            </td>
                            <td data-label="Date">
                                <span class="date-cell">
                                    <i class="bi bi-calendar3 me-1 text-muted"></i>
                                    @item.CommentDate.ToString("dd.MM.yyyy")
                                </span>
                            </td>
                            <td data-label="Actions">
                                <div class="action-group">
                                    <a href="/Comment/UpdateComment/@item.CommentId"
                                       class="btn-action btn-edit"
                                       title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <button onclick="confirmDeleteReview('@item.CommentId', '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(item.NameSurname))')"
                                            class="btn-action btn-delete"
                                            title="Delete">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination-wrapper">
            <span class="page-info">Showing @Model.Count results</span>
            <nav aria-label="Pagination">
                <ul class="pagination pagination-sm">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="?page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteReviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
        <div class="modal-content" style="border-radius:14px;border:0;box-shadow:0 20px 60px rgba(0,0,0,.15)">
            <div class="modal-body p-4 text-center">
                <div style="width:60px;height:60px;background:#fff5f5;border-radius:50%;display:grid;place-items:center;margin:0 auto 1.25rem;font-size:1.5rem;color:#e53e3e;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h5 style="font-weight:700;font-size:1.1rem;color:#1a202c;margin-bottom:.5rem;">Review will be deleted</h5>
                <p class="text-muted" style="font-size:.875rem;" id="deleteReviewModalBody">Are you sure?</p>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 px-4 d-flex gap-2">
                <button type="button" class="btn btn-light flex-fill" data-bs-dismiss="modal" style="border-radius:10px;font-weight:600;">Cancel</button>
                <button id="confirmDeleteReviewBtn" class="btn btn-danger flex-fill" style="border-radius:10px;font-weight:600;">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let deleteReviewId = null;

        function confirmDeleteReview(id, name) {
            deleteReviewId = id;
            document.getElementById('deleteReviewModalBody').innerText =
                "'" + name + "' kullanıcısının yorumu kalıcı olarak silinecek. Emin misiniz?";
            new bootstrap.Modal(document.getElementById('deleteReviewModal')).show();
        }

        document.getElementById('confirmDeleteReviewBtn').addEventListener('click', function () {
            if (deleteReviewId) {
                fetch('/Comment/DeleteComment/' + deleteReviewId, { method: 'POST' })
                    .then(() => location.reload());
            }
        });
    </script>
}
